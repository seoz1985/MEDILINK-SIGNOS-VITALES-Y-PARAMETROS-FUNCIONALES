# === APP ===
APP_ENV=production
SECRET_KEY=CHANGE_ME

# === CORS (dominio de tu frontend) ===
CORS_ALLOW_ORIGINS=https://app.tudominio.com

# === MySQL (cPanel) ===
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cpaneluser_dbname
DB_USER=cpaneluser_dbuser
