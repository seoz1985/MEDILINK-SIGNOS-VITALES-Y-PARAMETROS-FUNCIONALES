# === AI ===
TRIAGE_MODEL_PATH=models_store/triage_model.joblib

# LLM externo (microservicio). NO correr LLM dentro de cPanel.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL_NAME=mistral
